#!/usr/bin/env bash
set -euo pipefail

: "${STOW_FOLDERS:=zsh,git,wezterm}"
: "${DOTFILES:=$HOME/.dotfiles}"

script="install"
case "${1:-}" in
    "")        ;;
    --clean)   script="clean-env" ;;
    --help|-h)
        echo "Usage: ./ubuntu [--clean | --help]"
        exit 0
        ;;
    *)
        echo "unknown arg: $1" >&2
        exit 1
        ;;
esac

if [[ "$script" == "install" ]]; then
    apt_pkgs=(zsh stow git curl build-essential)
    if ! dpkg -s "${apt_pkgs[@]}" &>/dev/null; then
        sudo apt update
        sudo apt install -y "${apt_pkgs[@]}"
    fi

    zsh_path="$(command -v zsh)"
    if [[ "$(getent passwd "$USER" | cut -d: -f7)" != "$zsh_path" ]]; then
        sudo chsh -s "$zsh_path" "$USER"
    fi

    if [[ ! -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

    if [[ -f "$DOTFILES/Brewfile" ]]; then
        brew bundle --file="$DOTFILES/Brewfile"
    fi
fi

STOW_FOLDERS="$STOW_FOLDERS" DOTFILES="$DOTFILES" "$DOTFILES/$script"
